# App General Settings
APP_NAME=llm-cost-latency-monitor
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database Connection Details
# The service runs WITHOUT a database (in-memory fallback) if this is
# unreachable. When reachable, telemetry persists to PostgreSQL.
# Use host.docker.internal from containers, or localhost from the host.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0

# Celery (report generation / budget checks run async on a worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Budget Alerts
# Total USD spend over this triggers a flagged alert at /budgets/alerts.
BUDGET_THRESHOLD_USD=10.0
# Optional per-model USD budget (leave unset to disable per-model alerts).
# BUDGET_PER_MODEL_THRESHOLD_USD=5.0

# External APIs
# Leave as placeholders to run fully offline (mocked LLM responses).
# Set real keys to enable the real OpenAI/Anthropic path in MonitoredLLMClient.
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GITHUB_TOKEN=your-github-token
